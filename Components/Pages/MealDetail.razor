@page "/meal/{Id:int}"
@inject HNM.Services.NutritionService NutritionService
@inject NavigationManager Nav

<MudContainer MaxWidth="MaxWidth.Medium">

    <MudButton StartIcon="@Icons.Material.Filled.ArrowBack"
               Color="Color.Primary"
               OnClick="GoBack"
               Class="mb-4 px-0">
        返回 @meal.Date 飲食日誌
    </MudButton>

    @* MealDetail.razor *@
    <MudText Typo="Typo.h4" Class="mb-4 d-flex align-center" Style="word-break: break-all;">
        @meal.Name
        <MudChip T="string" Color="Color.Secondary" Size="Size.Small" Class="ml-3">
            @meal.MealType
        </MudChip>
    </MudText>

    <MudCard Elevation="2" Class="rounded-lg">
        <MudImage Src="@meal.Image"
                  Fluid="true"
                  Style="height: 450px; width: 100%;"
                  ObjectFit="ObjectFit.Cover" />
    </MudCard>

    <MudText Typo="Typo.h6" Class="mt-6 mb-3">
        營養資訊
    </MudText>

    


    <MudGrid>
        <MudItem xs="6">
            <MudPaper Class="pa-4 text-center">
                <MudText Typo="Typo.caption">熱量</MudText>
                <MudText Typo="Typo.h5" Color="Color.Primary">@meal.Calories kcal</MudText>
            </MudPaper>
        </MudItem>

        <MudItem xs="6">
            <MudPaper Class="pa-4 text-center">
                <MudText Typo="Typo.caption">蛋白質</MudText>
                <MudText Typo="Typo.h5">@meal.Protein g</MudText>
            </MudPaper>
        </MudItem>

        <MudItem xs="6">
            <MudPaper Class="pa-4 text-center">
                <MudText Typo="Typo.caption">碳水</MudText>
                <MudText Typo="Typo.h5">@meal.Carbs g</MudText>
            </MudPaper>
        </MudItem>

        <MudItem xs="6">
            <MudPaper Class="pa-4 text-center">
                <MudText Typo="Typo.caption">脂肪</MudText>
                <MudText Typo="Typo.h5">@meal.Fat g</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudDivider Class="my-6" />
    @* MealDetail.razor *@
    <MudDivider Class="my-6" />

    <MudText Typo="Typo.h6" Class="mb-3">辨識食材內容</MudText>
    <MudPaper Class="pa-4 mb-6" Elevation="0" Style="background-color: #F5F5F5;">
        <MudText Typo="Typo.body1" Style="word-break: break-all;">@meal.Ingredients</MudText>
    </MudPaper>

    @* 備註資訊部分 *@
    @if (!string.IsNullOrEmpty(meal.Notes))
    {
        <MudText Typo="Typo.h6" Class="mb-3">備註資訊</MudText>
        <MudPaper Class="pa-4 mb-6" Elevation="0" Style="background-color: #FFFDE7; border-left: 4px solid #FBC02D;">
            <MudText Typo="Typo.body2" Style="word-break: break-all;">@meal.Notes</MudText>
        </MudPaper>
    }

    @* 1. 修正紀錄時間字體 *@
    <MudText Typo="Typo.subtitle1" Class="mt-3" Style="font-weight:bold;">
        紀錄時間
    </MudText>

    <MudText Typo="Typo.body1" Class="mb-4">
        @meal.Date @meal.Time
    </MudText>

    <MudText Typo="Typo.subtitle1" Style="font-weight:bold;">
        AI 辨識可信度
    </MudText>

    <div class="d-flex align-center mt-1">
        <MudChip T="string" Color="Color.Success" Size="Size.Medium" Class="ml-0">
            @((meal.Confidence * 100).ToString("F0"))%
        </MudChip>
    </div>


    @* 🌟 這裡新增刪除按鈕 *@
    <MudDivider Class="my-8" />
    <MudButton Variant="Variant.Filled"
               Color="Color.Error"
               Size="Size.Large"
               FullWidth="true"
               StartIcon="@Icons.Material.Filled.Delete"
               OnClick="DeleteRecord"
               Class="mb-6">
        刪除此筆紀錄
    </MudButton>

</MudContainer>


@code {
    [Parameter]
    public int Id { get; set; }
    
    MealRecord meal = new();

    protected override void OnInitialized()
    {
        // 呼叫我們在 Service 寫好的方法，根據網址傳來的 Id 抓資料
        meal = NutritionService.GetMealById(Id);
    }

    private void GoBack()
    {
        if (!string.IsNullOrEmpty(meal.Date))
        {
            Nav.NavigateTo($"/diet-log/{meal.Date}");
        }
        else
        {
            Nav.NavigateTo("/diet-log");
        }
    }

    // 🌟 這裡新增刪除方法
    private void DeleteRecord()
    {
        // 1. 呼叫 Service 刪除這筆資料
        // (注意：請確認你的 NutritionService 裡面有寫好 DeleteMeal 或是 RemoveMeal 的方法)
        NutritionService.DeleteMeal(Id);

        // 2. 刪除後跳轉回該日期的日誌頁面
        if (!string.IsNullOrEmpty(meal.Date))
        {
            Nav.NavigateTo($"/diet-log/{meal.Date}");
        }
        else
        {
            Nav.NavigateTo("/diet-log");
        }
    }
}