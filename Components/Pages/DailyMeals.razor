@page "/diet-log/{Date}"
@inject HNM.Services.NutritionService NutritionService
@inject NavigationManager Nav

<MudContainer MaxWidth="MaxWidth.Large">

    <MudButton StartIcon="@Icons.Material.Filled.ArrowBack" Color="Color.Primary" OnClick="GoBack" Class="mb-4 px-0">
        返回日期列表
    </MudButton>

    <MudText Typo="Typo.h4" Class="mb-6">
        @Date 飲食紀錄
    </MudText>

    <MudPaper Class="pa-5 mb-8 rounded-xl" Elevation="2" Style="background-color: #F8FAF9; border-left: 6px solid #009688;">
        <div class="d-flex align-center justify-space-between mb-3">
            <MudText Typo="Typo.subtitle1" Color="Color.Default" Style="font-weight:bold;">當日攝取總計</MudText>
            <MudText Typo="Typo.h4" Color="Color.Primary" Style="font-weight:bold;">
                @TotalCalories.ToString("N0") <span style="font-size: 1rem; color: gray; font-weight: normal;">kcal</span>
            </MudText>
        </div>
    
        <MudDivider Class="mb-4" />
    
        <div class="d-flex justify-space-between text-center">
            <div style="flex: 1;">
                <MudText Typo="Typo.caption" Color="Color.Secondary">早餐</MudText>
                <MudText Typo="Typo.body2" Style="font-weight:bold;">@BreakfastCalories kcal</MudText>
            </div>
            <div style="flex: 1;">
                <MudText Typo="Typo.caption" Color="Color.Secondary">午餐</MudText>
                <MudText Typo="Typo.body2" Style="font-weight:bold;">@LunchCalories kcal</MudText>
            </div>
            <div style="flex: 1;">
                <MudText Typo="Typo.caption" Color="Color.Secondary">晚餐</MudText>
                <MudText Typo="Typo.body2" Style="font-weight:bold;">@DinnerCalories kcal</MudText>
            </div>
            <div style="flex: 1;">
                <MudText Typo="Typo.caption" Color="Color.Secondary">點心</MudText>
                <MudText Typo="Typo.body2" Style="font-weight:bold;">@SnackCalories kcal</MudText>
            </div>
        </div>
    </MudPaper>

    @foreach (var category in new[] { "早餐", "午餐", "晚餐", "點心", "宵夜" })
    {
        var mealsInCategory = DailyMealList.Where(m => m.MealType == category).ToList();
        
        @if (mealsInCategory.Any())
        {
            <div class="mt-8 mb-4">
                <div class="d-flex align-end justify-space-between mb-2">
                    <MudText Typo="Typo.h5" Color="Color.Dark">
                        <b>@category</b>
                    </MudText>
                </div>
                
                <MudPaper Class="px-4 py-2 rounded-pill d-flex justify-space-around" Elevation="0" Style="background-color: #E3F2FD;">
                    <MudText Typo="Typo.caption" Style="color: #5C6BC0;">蛋白質：<b>@mealsInCategory.Sum(i => i.Protein)</b>g</MudText>
                    <MudText Typo="Typo.caption" Style="color: #FB8C00;">碳水：<b>@mealsInCategory.Sum(i => i.Carbs)</b>g</MudText>
                    <MudText Typo="Typo.caption" Style="color: #7E57C2;">脂肪：<b>@mealsInCategory.Sum(i => i.Fat)</b>g</MudText>
                </MudPaper>
            </div>

            <MudGrid>
                @foreach (var meal in mealsInCategory)
                {
                    <MudItem xs="12" sm="6" md="4">
                        <MudCard Style="cursor:pointer" Elevation="3" @onclick="() => OpenDetail(meal.Id)">
                            <MudCardMedia Image="@meal.Image" Height="200" Style="object-fit: cover;" />
                            <MudCardContent>
                                <MudText Typo="Typo.h6">@meal.Name</MudText>
                                
                                <MudText Color="Color.Primary" Typo="Typo.subtitle1" Class="mt-1">
                                    <b>總計：@meal.Calories kcal</b>
                                </MudText>

                                <div class="d-flex justify-space-between mt-2">
                                    <MudText Typo="Typo.caption" Style="color: #5C6BC0;">蛋白質：<b>@meal.Protein</b>g</MudText>
                                    <MudText Typo="Typo.caption" Style="color: #FB8C00;">碳水：<b>@meal.Carbs</b>g</MudText>
                                    <MudText Typo="Typo.caption" Style="color: #7E57C2;">脂肪：<b>@meal.Fat</b>g</MudText>
                                </div>
                            </MudCardContent>
                        </MudCard>
                    </MudItem>
                }
            </MudGrid>
        }
    }

    @if (!DailyMealList.Any())
    {
        <MudAlert Severity="Severity.Info" Class="mt-6">這一天沒有任何飲食紀錄</MudAlert>
    }
</MudContainer>

@code {
    [Parameter]
    public string Date { get; set; } = "";

    List<MealRecord> DailyMealList = new();
    
    private int TotalCalories => DailyMealList.Sum(m => m.Calories);
    private int BreakfastCalories => DailyMealList.Where(m => m.MealType == "早餐").Sum(m => m.Calories);
    private int LunchCalories => DailyMealList.Where(m => m.MealType == "午餐").Sum(m => m.Calories);
    private int DinnerCalories => DailyMealList.Where(m => m.MealType == "晚餐").Sum(m => m.Calories);
    private int SnackCalories => DailyMealList.Where(m => m.MealType == "點心").Sum(m => m.Calories);

    protected override void OnInitialized()
    {
        var allMeals = NutritionService.GetAllMeals();
        DailyMealList = allMeals.Where(m => m.Date == Date).ToList();
    }

    void OpenDetail(int id)
    {
        Nav.NavigateTo($"/meal/{id}");
    }

    void GoBack()
    {
        Nav.NavigateTo("/diet-log");
    }
}