@inherits LayoutComponentBase

<MudThemeProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Dense="true" Color="Color.Primary">
        <MudText Typo="Typo.h6" Class="ml-3">食物營養辨識系統</MudText>
        <MudSpacer />
        <MudIconButton Icon="@Icons.Material.Filled.MoreVert" Color="Color.Inherit" />
    </MudAppBar>

    <MudMainContent Class="pa-0">
        <MudContainer MaxWidth="MaxWidth.Small" Style="min-height: 80vh;">
            @Body
        </MudContainer>
    </MudMainContent>

    <MudPaper Height="56px" Width="100%" Elevation="4" Style="position: fixed; bottom: 0; left: 0; right: 0; z-index: 1000;">
        <MudStack Row="true" Justify="Justify.SpaceAround" AlignItems="AlignItems.Center" Style="height: 100%">
            <MudIconButton Icon="@Icons.Material.Filled.Home" Color="Color.Primary" />
            <MudIconButton Icon="@Icons.Material.Filled.Mic" Color="Color.Default" />
            <MudIconButton Icon="@Icons.Material.Filled.History" Color="Color.Default" />
            <MudIconButton Icon="@Icons.Material.Filled.Person" Color="Color.Default" />
        </MudStack>
    </MudPaper>
</MudLayout>

<style>
    /* 讓內容不會被底部導覽列遮住 */
    .mud-main-content {
        padding-bottom: 60px !important;
    }
</style>