@inherits LayoutComponentBase
@inject NavigationManager NavManager
@implements IDisposable

<MudThemeProvider Theme="@_currentTheme" />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Surface">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Primary" Edge="Edge.Start" OnClick="@ToggleDrawer" />

        <MudButton OnClick='() => NavManager.NavigateTo("")'
                   Variant="Variant.Text"
                   Ripple="true"
                   Class="ml-2 px-2"
                   Style="text-transform: none;">
            <MudText Typo="Typo.h6" Color="Color.Primary" Style="font-weight:bold;">
                居家智慧營養監測系統
            </MudText>
        </MudButton>
        <MudSpacer />
    </MudAppBar>

    <MudDrawer @bind-Open="@_open"
               Variant="@DrawerVariant.Temporary"
               Elevation="1">

        <MudDrawerHeader Class="d-flex flex-column px-6 py-8">
            <MudText Typo="Typo.h5" Style="font-weight:bold; color:#009688; margin-bottom:4px;">選單導覽</MudText>
            <MudText Typo="Typo.body1" Style="color:#9E9E9E;">患者：XXX</MudText>
        </MudDrawerHeader>

        <MudNavMenu Class="mt-2">
            <MudNavLink Href="" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.BarChart" IconColor="Color.Info">
                數據總覽
            </MudNavLink>

            <MudNavLink Href="recognition" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.CameraAlt" IconColor="Color.Default">
                影像辨識
            </MudNavLink>

            <MudNavLink Href="diet-log" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.ReceiptLong" IconColor="Color.Warning">
                飲食日誌
            </MudNavLink>

            <MudNavLink Href="profile" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Person" IconColor="Color.Tertiary">
                個人檔案
            </MudNavLink>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Medium" Class="mt-4 pb-16">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    // 預設為 false (關閉)
    private bool _open = false;

    private void ToggleDrawer()
    {
        _open = !_open;
    }

    // 👇 配合最上方的指令，在這裡加入監聽網址改變的事件 👇
    protected override void OnInitialized()
    {
        NavManager.LocationChanged += CloseDrawer;
    }

    private void CloseDrawer(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        if (_open)
        {
            _open = false;
            StateHasChanged();
        }
    }

    public void Dispose()
    {
        NavManager.LocationChanged -= CloseDrawer;
    }
    // 👆 監聽功能結束 👆

    // 主題設定維持不變
    private MudTheme _currentTheme = new MudTheme()
    {
        PaletteLight = new PaletteLight()
        {
            Primary = "#009688",
            AppbarBackground = "#FFFFFF",
            Background = "#F5F7F9",
            TextPrimary = "#424242",
            ActionDefault = "#0096881A"
        }
    };
}